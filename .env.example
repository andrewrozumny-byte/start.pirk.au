# ─── Local dev: SQLite (no Turso needed) ─────────────────────────────────────
# Leave TURSO_* unset for local development. Uses prisma/pirk.db.

# ─── Vercel / Production: Turso (required on Vercel) ──────────────────────────
# Get from: turso db create pirk && turso db tokens create pirk && turso db show pirk --url
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Optional for Prisma CLI (e.g. migrate diff). Local SQLite:
# DATABASE_URL=file:./prisma/pirk.db

# ─── Payments (Stripe) ───────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID=
STRIPE_PRICE_ID_GUIDED=
STRIPE_PRICE_ID_CONCIERGE=
# Webhook secret if using Stripe webhooks (optional)
# STRIPE_WEBHOOK_SECRET=

# ─── Public / frontend ───────────────────────────────────────────────────────
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# ─── AI matching (Anthropic) ──────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ─── Analytics (optional) ────────────────────────────────────────────────────
# NEXT_PUBLIC_META_PIXEL_ID=
# NEXT_PUBLIC_TIKTOK_PIXEL_ID=
